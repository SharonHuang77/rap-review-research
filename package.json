{
  "name": "rap-review-research",
  "version": "0.1.0",
  "private": true,
  "description": "AI Code Review Experiment Platform — Experiment Engine (RFC-01)",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --test \"tests/unit/**/*.test.ts\"",
    "test:watch": "node --test --watch \"tests/unit/**/*.test.ts\"",
    "demo": "node scripts/demo-experiment-engine.ts",
    "demo:import": "node scripts/demo-pr-import.ts",
    "demo:framework": "node scripts/demo-review-framework.ts",
    "demo:agentless": "node scripts/demo-agentless.ts",
    "demo:hierarchical": "node scripts/demo-hierarchical.ts",
    "demo:consensus": "node scripts/demo-consensus.ts",
    "demo:evaluate": "node scripts/demo-evaluation.ts",
    "demo:export": "node scripts/demo-export.ts",
    "demo:workbench": "node scripts/demo-workbench.ts",
    "dashboard": "node apps/research-workbench/server.ts",
    "benchmark:import": "node scripts/benchmark-import.ts",
    "benchmark:run": "node scripts/benchmark-run.ts",
    "benchmark:evaluate": "node scripts/benchmark-evaluate.ts",
    "benchmark:export": "node scripts/benchmark-export.ts",
    "campaign:run": "node scripts/campaign-run.ts",
    "campaign:live": "node scripts/campaign-live.ts",
    "verify:replay": "node scripts/verify-replay.ts",
    "smoke:bedrock": "node scripts/smoke-bedrock.ts",
    "check": "npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1076.0",
    "zod": "^3.25.76"
